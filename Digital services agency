<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Poppins',sans-serif;
scroll-behavior:smooth;
}

body{
background:#0f0f14;
color:#fff;
}

/* NAVBAR */
nav{
position:fixed;
width:100%;
padding:18px 8%;
display:flex;
justify-content:space-between;
align-items:center;
background:rgba(0,0,0,0.9);
backdrop-filter:blur(10px);
z-index:1000;
}

nav h1{
font-size:28px;
font-weight:700;
background:linear-gradient(90deg,#00f5ff,#ff00c8);
-webkit-background-clip:text;
color:transparent;
}

nav a{
color:#fff;
margin-left:25px;
text-decoration:none;
font-weight:500;
transition:.3s;
}

nav a:hover{
color:#00f5ff;
}

/* HERO */
.hero{
min-height:100vh;
display:flex;
flex-direction:column;
justify-content:center;
align-items:center;
text-align:center;
padding:120px 20px 60px;
background:radial-gradient(circle at top,#1c1c2b,#0f0f14);
}

.hero-img{
width:200px;
height:200px;
border-radius:50%;
overflow:hidden;
border:4px solid #00f5ff;
box-shadow:0 0 40px #00f5ff;
margin-bottom:25px;
}

.hero-img img{
width:100%;
height:100%;
object-fit:cover;
}

.hero h2{
font-size:42px;
margin-bottom:15px;
}

.hero p{
max-width:750px;
line-height:1.8;
opacity:.85;
}

.btn{
margin-top:25px;
display:inline-block;
padding:12px 28px;
border-radius:30px;
background:linear-gradient(90deg,#00f5ff,#ff00c8);
color:#fff;
text-decoration:none;
font-weight:600;
transition:.3s;
}

.btn:hover{
transform:scale(1.05);
}

/* SECTIONS */
section{
padding:100px 8%;
}

.section-title{
text-align:center;
font-size:34px;
margin-bottom:60px;
}

/* PACKAGES */
.packages{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
gap:35px;
}

.card{
background:#1a1a25;
padding:25px;
border-radius:20px;
transition:.4s;
border:1px solid rgba(255,255,255,0.05);
}

.card:hover{
transform:translateY(-10px);
box-shadow:0 0 35px rgba(0,255,255,.3);
}

.package-img{
height:160px;
border-radius:15px;
display:flex;
align-items:center;
justify-content:center;
font-size:26px;
font-weight:700;
margin-bottom:20px;
letter-spacing:2px;
text-align:center;
padding:10px;
}

.basic{background:linear-gradient(135deg,#00f5ff,#0066ff);}
.starter{background:linear-gradient(135deg,#ff00c8,#ff6a00);}
.pro{background:linear-gradient(135deg,#00ff94,#0099ff);}
.high{background:linear-gradient(135deg,#ffcc00,#ff0066);}

.card h3{
margin-bottom:10px;
font-size:22px;
}

.price{
font-weight:700;
margin-bottom:15px;
color:#00f5ff;
}

.card ul{
list-style:none;
line-height:1.8;
opacity:.9;
}

.card ul li::before{
content:"✔ ";
color:#00f5ff;
}

/* CONTACT */
.contact{
text-align:center;
}

.contact a{
display:inline-block;
margin:10px;
padding:12px 25px;
border-radius:30px;
background:#1a1a25;
color:#fff;
text-decoration:none;
transition:.3s;
border:1px solid #00f5ff;
}

.contact a:hover{
background:#00f5ff;
color:#000;
}

/* FOOTER */
footer{
text-align:center;
padding:20px;
background:#0a0a0f;
opacity:.6;
}

@media(max-width:768px){
.hero h2{
font-size:30px;
}
.hero-img{
width:160px;
height:160px;
}
}
</style>
</head>

